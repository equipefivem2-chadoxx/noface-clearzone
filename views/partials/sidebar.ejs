<aside class="sidebar glass-panel">
    <div class="cad-brand">
        <div class="brand-top">
            <span class="status-dot pulse"></span>
            <span class="brand-subtext">SYS-OP // SECURE CHANNEL</span>
        </div>
        <h1>TACTICAL CONTROL</h1>
        <div class="dept-badge badge-<%= mapId %>">
            <%= mapId.toUpperCase() %> DISPATCH UNIT
        </div>
    </div>

    <div class="live-panel">
        <div class="panel-section-title">MONITORING TELEMETRY</div>
        <div class="status-grid">
            <div class="status-card">
                <small>UPLINK</small>
                <strong class="text-success">CONNECTED</strong>
            </div>
            <div class="status-card">
                <small>FREQ</small>
                <strong>SECURE TAC-1</strong>
            </div>
            <div class="status-card">
                <small>DATABASE</small>
                <strong>LIVE SYNC</strong>
            </div>
        </div>
    </div>

    <div class="tools-panel">
        <div class="panel-section-title">TACTICAL GRAPH SYSTEM</div>
        <div class="tools-grid" id="tactical-tools">
            <button class="tool-btn active" data-tool="nav" title="Navigation">
                <span class="icon">◫</span> NAV MODE
            </button>
            <button class="tool-btn" data-tool="draw" data-size="5" title="Fluo Fin">
                <span class="icon">✎</span> CLEARZONE BRUSH
            </button>
            <button class="tool-btn" data-tool="eraser" title="Gomme">
                <span class="icon">⌫</span> ERASE LINE
            </button>
        </div>
    </div>

    <div class="deployment-panel">
        <button id="btn-new-unit" class="btn-tactical pulse" style="width: 100%;">
            [+] DEPLOY NEW UNIT
        </button>
    </div>

    <div class="units-panel">
        <div class="panel-section-title">ACTIVE FIELD DEPLOYMENTS</div>
        <div id="units-list" class="custom-scroll">
            <div class="empty-state">NO ACTIVE DEPLOYMENT IN GRID</div>
        </div>
    </div>
</aside>

<style>
.sidebar {
    width: 380px;
    height: calc(100vh - 100px);
    position: fixed;
    right: 20px;
    top: 80px;
    z-index: 1000;
    padding: 25px;
    display: flex;
    flex-direction: column;
    gap: 25px;
}
.cad-brand h1 {
    font-family: var(--font-hud);
    font-size: 22px;
    letter-spacing: 2px;
    margin: 5px 0;
}
.brand-top {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-muted);
}
.status-dot {
    width: 6px;
    height: 6px;
    background: var(--success);
    border-radius: 50%;
}
.dept-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 3px 10px;
    background: rgba(255,255,255,0.05);
    border-left: 3px solid var(--accent);
    margin-top: 5px;
}
.panel-section-title {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 1px;
    margin-bottom: 10px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    padding-bottom: 4px;
}
.status-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
}
.status-card {
    background: rgba(0,0,0,0.3);
    padding: 10px;
    border: 1px solid rgba(255,255,255,0.03);
    font-size: 13px;
}
.status-card small {
    display: block;
    color: var(--text-muted);
    font-size: 9px;
    font-family: var(--font-mono);
}
.tools-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 8px;
}
.tool-btn {
    background: rgba(0,0,0,0.2);
    border: 1px solid rgba(255,255,255,0.08);
    color: var(--text-primary);
    padding: 12px;
    text-align: left;
    font-family: var(--font-hud);
    font-size: 11px;
    letter-spacing: 1px;
    cursor: pointer;
    transition: all 0.2s ease;
}
.tool-btn:hover, .tool-btn.active {
    border-color: var(--accent);
    background: rgba(0, 210, 255, 0.05);
    color: var(--accent);
    text-shadow: 0 0 8px var(--accent-glow);
}
.custom-scroll {
    overflow-y: auto;
    flex-grow: 1;
    padding-right: 5px;
}
.custom-scroll::-webkit-scrollbar { width: 4px; }
.custom-scroll::-webkit-scrollbar-thumb { background: var(--panel-border); }

/* CARTE DE CHAQUE UNITÉ ACTIVE */
.unit-card-active {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.05);
    padding: 12px;
    margin-bottom: 8px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    transition: all 0.2s ease;
}
.unit-card-active:hover {
    background: rgba(255,255,255,0.05);
}
.unit-card-active.selected {
    border-color: var(--unit-color);
    box-shadow: inset 0 0 10px rgba(0,0,0,0.5);
    background: rgba(0,0,0,0.4);
}
.unit-info-block {
    display: flex;
    flex-direction: column;
}
.unit-name-title {
    font-family: var(--font-hud);
    font-size: 14px;
    color: #fff;
}
.unit-status-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    margin-top: 2px;
}
.btn-delete-unit {
    background: transparent;
    border: none;
    color: var(--danger);
    font-size: 18px;
    cursor: pointer;
    padding: 0 5px;
}
.empty-state {
    text-align: center;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 12px;
    padding: 30px 0;
}
</style>