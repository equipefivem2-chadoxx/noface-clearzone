<aside class="right-panel glass-panel">
    <div class="panel-header">
        <h3>Unités Actives</h3>
        <button id="btn-new-unit" class="btn-primary">+ Nouvelle Unité</button>
    </div>

    <div id="units-list" class="units-list">
        <!-- Les unités seront injectées ici via JS/Socket -->
        <% if (units && units.length > 0) { %>
            <% units.forEach(unit => { %>
                <div class="unit-card" data-id="<%= unit.id %>" data-color="<%= unit.color %>">
                    <div class="unit-color" style="--u-color: <%= unit.color %>;"></div>
                    <span class="unit-name"><%= unit.name %></span>
                    <button class="btn-select">Sélectionner</button>
                    <button class="btn-delete">✕</button>
                </div>
            <% }); %>
        <% } else { %>
            <div class="empty-state">Aucune unité déployée.</div>
        <% } %>
    </div>
</aside>

<!-- Modal Création d'unité -->
<div id="modal-unit" class="modal-overlay hidden">
    <div class="modal glass-panel">
        <h3>Déployer une unité</h3>
        <input type="text" id="unit-name-input" placeholder="Ex: Charlie-2, A141..." autocomplete="off">
        <div id="modal-error" class="error-text"></div>
        <div class="modal-actions">
            <button id="btn-cancel-unit" class="btn-secondary">Annuler</button>
            <button id="btn-confirm-unit" class="btn-primary">Confirmer</button>
        </div>
    </div>
</div>