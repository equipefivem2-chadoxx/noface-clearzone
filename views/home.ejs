<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <main class="home-container">
        <h1 class="home-title">Tactical Operations Map</h1>
        <p class="home-subtitle">Coordination en temps réel des unités de San Andreas.</p>

        <div class="cards-grid">
            <a href="/map/bcso" class="dept-card glass-panel bcso">
                <h2>BCSO</h2>
                <p>Carte réservée au Blaine County Sheriff's Office.</p>
                <div class="btn-access">Accéder</div>
            </a>

            <a href="/map/lspd" class="dept-card glass-panel lspd">
                <h2>LSPD</h2>
                <p>Carte réservée au Los Santos Police Department.</p>
                <div class="btn-access">Accéder</div>
            </a>

            <a href="/map/all" class="dept-card glass-panel all">
                <h2>COMMUN</h2>
                <p>Carte regroupant le BCSO et le LSPD.</p>
                <div class="btn-access">Accéder</div>
            </a>
        </div>
    </main>
</body>
</html>