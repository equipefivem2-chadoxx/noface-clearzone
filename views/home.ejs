<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CLEARZONE - Command Center</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Rajdhani:wght@500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/home.css">
</head>
<body>

    <div id="startup-screen">
        <div class="startup-content">
            <div class="spinner"></div>
            <div class="startup-text">INITIALIZING SYSTEM...</div>
        </div>
    </div>

    <main class="dashboard-wrapper">
        
        <header class="topbar">
            <div class="topbar-left">
                <div class="brand">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
                    <span>CLEARZONE <span class="badge">v2.0</span></span>
                </div>
            </div>
            <div class="topbar-right">
                <div class="status-pill">
                    <span class="dot pulse-green"></span>
                    <span>SECURE NETWORK ONLINE</span>
                </div>
                <div class="time-display" id="local-time">00:00:00</div>
            </div>
        </header>

        <section class="hero-section">
            <h1 class="main-title">TACTICAL OPERATIONS</h1>
            <p class="sub-title">SELECT A COMMAND NODE TO INITIALIZE SAT-LINK</p>
        </section>

        <section class="nodes-grid">
            
            <a href="/map/bcso" class="node-card bcso-theme">
                <div class="card-header">
                    <span class="node-id">NODE-01</span>
                    <span class="status ready">READY</span>
                </div>
                <div class="card-icon">
                    <img src="/assets/bcso.png" alt="BCSO" onerror="this.src='data:image/svg+xml;utf8,<svg viewBox=\'0 0 24 24\' fill=\'none\' stroke=\'%23f59e0b\' stroke-width=\'1\'><circle cx=\'12\' cy=\'12\' r=\'10\'/></svg>'">
                </div>
                <div class="card-body">
                    <h2>BCSO</h2>
                    <p>Blaine County Sheriff's Office<br>Tactical Mapping Division</p>
                </div>
                <div class="card-footer">
                    <span>CONNECT TO GRID</span>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </div>
            </a>

            <a href="/map/lspd" class="node-card lspd-theme">
                <div class="card-header">
                    <span class="node-id">NODE-02</span>
                    <span class="status ready">READY</span>
                </div>
                <div class="card-icon">
                    <img src="/assets/lspd.png" alt="LSPD" onerror="this.src='data:image/svg+xml;utf8,<svg viewBox=\'0 0 24 24\' fill=\'none\' stroke=\'%233b82f6\' stroke-width=\'1\'><circle cx=\'12\' cy=\'12\' r=\'10\'/></svg>'">
                </div>
                <div class="card-body">
                    <h2>LSPD</h2>
                    <p>Los Santos Police Department<br>Metropolitan Command</p>
                </div>
                <div class="card-footer">
                    <span>CONNECT TO GRID</span>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </div>
            </a>

            <a href="/map/all" class="node-card global-theme">
                <div class="card-header">
                    <span class="node-id">NODE-SA</span>
                    <span class="status active">ACTIVE</span>
                </div>
                <div class="card-icon">
                    <svg width="70" height="70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="2" y1="12" x2="22" y2="12"></line>
                        <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                    </svg>
                </div>
                <div class="card-body">
                    <h2>GLOBAL</h2>
                    <p>San Andreas State<br>Joint Task Force Network</p>
                </div>
                <div class="card-footer">
                    <span>CONNECT TO GRID</span>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </div>
            </a>

        </section>
        
        <footer class="bottom-footer">
            <p>CLEARZONE SECURE TERMINAL &copy; 2026. AUTHORIZED PERSONNEL ONLY.</p>
        </footer>

    </main>

    <script>
        // Séquence de démarrage très fluide
        window.addEventListener('load', () => {
            setTimeout(() => {
                const screen = document.getElementById('startup-screen');
                screen.style.opacity = '0';
                setTimeout(() => screen.remove(), 600);
            }, 800);
        });

        // Horloge temps réel
        function updateTime() {
            const now = new Date();
            document.getElementById('local-time').textContent = now.toLocaleTimeString('en-US', { hour12: false });
        }
        setInterval(updateTime, 1000);
        updateTime();
    </script>
</body>
</html>